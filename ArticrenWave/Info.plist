<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle Identity -->
    <key>CFBundleIdentifier</key>
    <string>ArticrenWaveAppStore</string>
    <key>CFBundleName</key>
    <string>Articren Wave</string>
    <key>CFBundleDisplayName</key>
    <string>Articren Wave</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Deployment -->
    <key>MinimumOSVersion</key>
    <string>16.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>

    <!-- Supported orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Scene config (SwiftUI lifecycle) -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>

    <!-- Privacy descriptions -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Articren Wave uses your photo library to let you set a profile avatar.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Articren Wave may use the microphone for future AR audio input features.</string>
    <key>NSCameraUsageDescription</key>
    <string>Articren Wave uses the camera for Augmented Reality score overlay features.</string>

    <!-- iCloud -->
    <key>NSUbiquitousContainers</key>
    <dict>
        <key>iCloud.ArticrenWaveAppStore</key>
        <dict>
            <key>NSUbiquitousContainerIsDocumentScopePublic</key>
            <true/>
            <key>NSUbiquitousContainerName</key>
            <string>ArticrenWave</string>
            <key>NSUbiquitousContainerSupportedFolderLevels</key>
            <string>Any</string>
        </dict>
    </dict>

    <!-- File types -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Articren Wave Score</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.dartmeadow.articrenwave.score</string>
            </array>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>awscore</string>
            </array>
        </dict>
    </dict>

    <!-- Exported UTI -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.dartmeadow.articrenwave.score</string>
            <key>UTTypeDescription</key>
            <string>Articren Wave Score</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
                <string>public.json</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>awscore</string>
                </array>
            </dict>
        </dict>
    </dict>

    <!-- App appearance -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIUserInterfaceStyle</key>
    <string>Dark</string>
</dict>
</plist>
